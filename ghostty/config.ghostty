theme = dark:Ayu , light:Ayu Light

cursor-style = block
shell-integration-features = no-cursor

font-size = 11
adjust-cell-height = 20%

keybind = ctrl+enter=text:\n

font-family = "Monaspace Neon"
font-feature = calt
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss05

confirm-close-surface = false
