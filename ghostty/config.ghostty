theme = dark:Ayu,light:Ayu Light
font-size = 13
keybind = ctrl+enter=text:\n
font-family = "Monaspace Neon"
adjust-cell-height = 30%
font-feature = calt
font-feature = ss01
font-feature = ss02
font-feature = ss03
font-feature = ss05
confirm-close-surface = false
window-padding-x = 5
window-padding-y = 5
