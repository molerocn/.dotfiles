[
  // VIM INSERT CONTEXT
  // save with ctrl-s in insert mode
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-s": ["workspace::SendKeystrokes", "escape ctrl-s"],
    },
  },
  // VIM VISUAL CONTEXT
  // yanked text to clipboard
  // move line up and down
  // save just pressing s key
  // unmap ctrl-b
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space y": ["workspace::SendKeystrokes", "\" + y escape"],
      "shift-h": "editor::MoveLineUp",
      "shift-m": "editor::MoveLineDown",
      "s": ["workspace::SendKeystrokes", "escape ctrl-s"],
      "ctrl-b": null,
    },
  },
  // VIM NORMAL CONTEXT
  // remove line and save with leader d
  // save just pressing s key
  // harpoon bindings
  // fuzzy finder for projects
  // close search bar within buffer
  // unmap shift-h
  // unmap ctrl-b
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space d": ["workspace::SendKeystrokes", "d d ctrl-s"],
      "s": ["workspace::SendKeystrokes", "escape ctrl-s"],
      "ctrl-h": ["pane::ActivateItem", 0],
      "ctrl-t": ["pane::ActivateItem", 1],
      "ctrl-n": ["pane::ActivateItem", 2],
      "ctrl-m": ["pane::ActivateItem", 3],
      "ctrl-f": ["projects::OpenRecent", { "create_new_window": true }],
      "ctrl-shift-c": "buffer_search::Dismiss",
      "shift-h": null,
      "ctrl-b": null,
    },
  },
  // WORKSPACE CONTEXT
  // fuzzy finder for projects
  // toggle terminal
  // swap tabs using ctrl and < or >
  // unmap ctrl-shift-s
  // unmap ctrl-alt-o
  // unmap ctrl-b
  // unmap ctrl-shift-n
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-f": ["projects::OpenRecent", { "create_new_window": true }],
      "ctrl-/": "terminal_panel::Toggle",
      "ctrl-<": "pane::SwapItemLeft",
      "ctrl->": "pane::SwapItemRight",
      "ctrl-shift-s": null, // save as
      "ctrl-alt-o": null, // open project (ctrl-f behaviour)
      "ctrl-b": null, // ToggleLeftDock
      "ctrl-shift-n": null, // NewWindow
    },
  },
  // TERMINAL CONTEXT
  // respetar keymaps ctrl-n ctrl-p
  // ctrl + enter = enter
  // keymaps to navigate across terminal panes
  // create new terminal
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-p": null,
      "ctrl-n": null,
      "ctrl-enter": ["terminal::SendText", "\r"],
      "ctrl-h": "pane::ActivatePreviousItem",
      "ctrl-t": "pane::ActivateNextItem",
      "ctrl-shift-n": "workspace::NewTerminal",
    },
  },
  // TERMINAL CONTEXT for WINDOWS
  // clear line using ctrl + u like linux
  {
    "context": "Terminal && os == windows",
    "bindings": {
      "ctrl-u": ["terminal::SendText", "\u001b"],
      // probar esto para windows
      // "ctrl-p": ["terminal::SendText", "\u001b[A"],
      // "ctrl-n": ["terminal::SendText", "\u001b[B"],
    },
  },
  // EDITOR CONTEXT
  // unmap ctrl - >
  // unmap ctrl - <
  // unbind ctrl-/
  {
    "context": "Editor",
    "unbind": {
      "ctrl->": "agent::AddSelectionToThread",
      "ctrl-<": "assistant::InsertIntoEditor",
      "ctrl-/": ["editor::ToggleComments", { "advance_downwards": false }],
    },
  },
  // EDITOR CONTEXT WITH EVENT
  // lsp completion
  // close menus using ctrl-c
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-y": "editor::ComposeCompletion",
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "ctrl-c": "menu::Cancel",
    },
  },
  {
    "context": "BufferSearchBar > Editor",
    "bindings": {
      "ctrl-c": "buffer_search::Dismiss",
    },
  },
  // PROJECT PANEL CONTEXT
  // fuzzy finder for files
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "ctrl-p": "file_finder::Toggle",
    },
  },
  // PROJECT PANEL CONTEXT
  // fuzzy finder for files
  {
    "context": "GitPanel",
    "bindings": {
      "ctrl-p": "file_finder::Toggle",
    },
  },
]
