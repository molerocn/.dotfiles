#!/usr/bin/env bash

NB_DIR="./notebooks"

selected_file=$(find -L "$NB_DIR" -name '*.py' 2>/dev/null | sort -Vr | fzf --no-sort)

if [[ -n "$selected_file" ]]; then
    uv run marimo edit "$selected_file" > /dev/null 2>&1 &
fi

