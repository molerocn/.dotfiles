#!/usr/bin/env bash
# Utilidad para imprimir la ruta original al navegar con tmux

if [ -z "$TMUX" ]; then
    echo "$HOME"
    exit 0
fi

session=$(tmux display-message -p '#S' 2>/dev/null) || {
    exit 1
}

root=$(tmux show-environment -t "$session" SESSION_ROOT 2>/dev/null | sed 's/^SESSION_ROOT=//')

if [ -z "$root" ]; then
    exit 1
fi

# Imprime la ruta para que la terminal la atrape
echo "$root"
