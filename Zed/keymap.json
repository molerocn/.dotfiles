[
  // guardar en insert mode
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-s": ["workspace::SendKeystrokes", "escape : w a enter"],
    },
  },
  // para copiar con leader y
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space y": ["workspace::SendKeystrokes", "\" + y escape"],
    },
  },
  // acceder al sidebar
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "space v": "pane::RevealInProjectPanel",
    },
  },
  // completar con ctrl + y
  {
    "context": "Editor && showing_completions",
    "bindings": {
      "ctrl-y": "editor::ComposeCompletion",
    },
  },
  // close with ctrl + c
  {
    "context": "Editor",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-c": "editor::Cancel",
    },
  },
  {
    "context": "Picker > Editor",
    "bindings": {
      "ctrl-c": "menu::Cancel",
    },
  },
]
